# UrbanTrends — Caddy reverse proxy config.
#
# Copy to /etc/caddy/Caddyfile (or import from your global Caddyfile).
# Caddy provisions and renews Let's Encrypt certificates automatically.
#
# Assumes docker compose is running with:
#   backend  → 127.0.0.1:8000
#   frontend → 127.0.0.1:3000

# Public website — all traffic goes to Next.js.
# next.config.ts rewrites proxy /_allauth/*, /api/*, and /accounts/* to the
# backend container over the internal Docker network, so no path splits needed.
urbantrends.dev, www.urbantrends.dev {
    reverse_proxy localhost:3000
}

# Django backend — admin dashboard and direct API access.
# Django reads X-Forwarded-Proto to determine request.is_secure(), which is
# required for WebAuthn origin checks and secure-cookie delivery.
api.urbantrends.dev {
    reverse_proxy localhost:8000 {
        header_up X-Forwarded-Proto {scheme}
    }
}
