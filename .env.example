# =============================================================================
# UrbanTrends — Docker Compose environment
# =============================================================================
# Copy to .env (gitignored) and fill in real values:  cp .env.example .env
#
# Two env sources are in play:
#   1. THIS FILE (.env at repo root) — consumed by docker-compose.yml for the
#      Postgres credentials and the frontend's public site URL.
#   2. ut-backend/.env — the Django app's own secrets (Resend, GitHub, Google,
#      SECRET_KEY, etc.). Compose loads it into the backend via `env_file`.
#      It is NEVER copied into the image. Keep that file as you already have it.
# =============================================================================

# --- Postgres (used by the `db` service and to build DATABASE_URL) -----------
POSTGRES_USER=urbantrends
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=urbantrends

# --- Frontend public config --------------------------------------------------
# Inlined into the client bundle at build time AND passed at runtime.
NEXT_PUBLIC_SITE_URL=https://urbantrends.dev

# =============================================================================
# Reference: variables that belong in ut-backend/.env (NOT this file)
# Listed here so you don't forget them when provisioning a fresh VPS.
# =============================================================================
# SECRET_KEY=<long-random-string>
# DEBUG=False
# ALLOWED_HOSTS=api.urbantrends.dev
# CSRF_TRUSTED_ORIGINS=https://urbantrends.dev,https://www.urbantrends.dev,https://api.urbantrends.dev
# FRONTEND_BASE_URL=https://urbantrends.dev
# WEBAUTHN_RP_ID=urbantrends.dev
# RESEND_API_KEY=<resend-key>
# DEFAULT_FROM_EMAIL=noreply@urbantrends.dev
# STAFF_NOTIFICATION_EMAIL=ops@urbantrends.dev
#
# DATABASE_URL is injected automatically by docker-compose.yml from the
# POSTGRES_* values above — do NOT set it manually in ut-backend/.env, or it
# will override the container networking (host should be `db`, not localhost).
#
# Integrations (optional, leave blank until enabled):
# GITHUB_TOKEN=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_OAUTH_REDIRECT_URI=https://api.urbantrends.dev/api/github/callback
# GITHUB_WEBHOOK_SECRET=
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=
